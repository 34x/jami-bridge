# Development image for jami-sdk.
#
# This is a thin layer on top of jami-sdk-base that adds only the
# SDK build dependencies (nlohmann-json). Source code is NOT copied
# into the image — instead, it's mounted at runtime for fast
# incremental builds.
#
# Build once:  podman build -t jami-sdk-dev -f Containerfile.dev .
# Develop:    ./build.sh dev
# Shell:      ./build.sh dev-shell
#
# The dev workflow mounts the host source directory and builds
# incrementally inside the container. The output binary appears
# on the host filesystem (jami-sdk/build/jami-sdk).

FROM jami-sdk-base

RUN dnf install -y nlohmann-json-devel patchelf && dnf clean all

# Create build directory so the mount target exists
RUN mkdir -p /build/jami-sdk/build

WORKDIR /build/jami-sdk

# Default: run cmake + make
# Source is mounted at runtime, not baked in.
CMD ["bash", "-c", "cd build && cmake .. -DJAMI_INCLUDE_DIR=/usr/local/include/jami -DJAMI_LIBRARY=/usr/local/lib64/libjami.so && make -j$(nproc)"]